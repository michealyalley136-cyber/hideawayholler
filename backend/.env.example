# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/hollerhub?schema=public"

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# File uploads (local dev; swap for S3 in production)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Optional S3 (future)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=hollerhub-uploads
