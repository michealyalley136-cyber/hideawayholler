generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  APPLICANT
  RESIDENT
  ALUMNI
  ADMIN
  SUPER_ADMIN
}

enum ResidentStatus {
  APPLICANT
  APPROVED
  LEASE_SENT
  LEASE_SIGNED
  DEPOSIT_RECEIVED
  ROOM_ASSIGNED
  CHECKED_IN
  ACTIVE_RESIDENT
  CHECKED_OUT
  ALUMNI
}

enum DocumentType {
  PASSPORT
  VISA
  JOB_OFFER
  OTHER
}

enum PaymentStatus {
  PAID
  PARTIAL
  DUE
  OVERDUE
}

enum PaymentType {
  RENT
  DEPOSIT
  OTHER
}

enum BusinessSubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

enum BusinessInvoiceStatus {
  DRAFT
  PENDING
  OPEN
  PAID
  FAILED
  OVERDUE
  WAIVED
  VOID
  UNCOLLECTIBLE
}

enum BusinessInvoiceType {
  SETUP_FEE
  MONTHLY_SUBSCRIPTION
  CUSTOM_CHARGE
}

enum BillingFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ClientSubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  INCOMPLETE
}

enum BusinessPaymentMethod {
  STRIPE
  MANUAL
  CHECK
  WIRE
  OTHER
}

enum BusinessPaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELED
}

enum BusinessSetupFeeStatus {
  NOT_SENT
  PENDING
  PAID
  WAIVED
  FAILED
  NOT_REQUIRED
}

enum NoticeCategory {
  RULES
  COMMUNITY
  RENT_REMINDER
  WEATHER
  EMERGENCY
  EVENT
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  APPLIANCE
  CLEANING
  OTHER
}

enum MaintenanceStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
}

enum LocalGuideCategory {
  FOOD
  SHOPPING
  TRANSPORTATION
  HEALTHCARE
  BANKS
  ATTRACTIONS
  EMERGENCY
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
}

enum SupplyType {
  TOILET_PAPER
  PAPER_TOWELS
  TRASH_BAGS
  CLEANING_SUPPLIES
  DISH_SOAP
  LAUNDRY_SUPPLIES
  OTHER
}

enum SupplyRequestStatus {
  OPEN
  FULFILLED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SosAlertStatus {
  ACTIVE
  ACKNOWLEDGED
  SAFE
  NEEDS_HELP
  RESOLVED
}

enum SosEventType {
  SOS_TRIGGERED
  ADMIN_NOTIFIED
  ADMIN_ACKNOWLEDGED
  RESIDENT_CONFIRMED_SAFE
  TRACKING_STARTED
  LOCATION_UPDATED
  ADMIN_MARKED_RESOLVED
  SOS_RESOLVED
  SOS_MUTED
}

enum SosSoundKey {
  EMERGENCY_SIREN
  AIR_HORN
  ALERT_BELL
  CRITICAL_ALERT
  WARNING_TONE
}

enum HouseAssignmentStatus {
  ACTIVE
  ARCHIVED
}

enum LeaseWorkflowStatus {
  DRAFT
  ASSIGNED
  PENDING_SIGNATURE
  SIGNED_BY_RESIDENT
  APPROVED_BY_ADMIN
  COMPLETED
  ARCHIVED
}

enum CommunityPostType {
  RESIDENT_MEMORY
  ADMIN_EVENT
  ANNOUNCEMENT_PHOTO
  ANIMAL_MOMENT
  COMMUNITY_ACTIVITY
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReactionType {
  LIKE
  LOVE
  SMILE
}

enum ReportStatus {
  OPEN
  REVIEWED
  RESOLVED
}

model CommunityPost {
  id              String              @id @default(uuid())
  authorId        String
  authorRole      UserRole
  caption         String?
  postType        CommunityPostType  @default(RESIDENT_MEMORY)
  approvalStatus  ApprovalStatus      @default(PENDING)
  isPinned        Boolean             @default(false)
  commentsEnabled Boolean             @default(true)
  isOfficial      Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  author    User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  images    CommunityPostImage[]
  comments  CommunityComment[]
  reactions CommunityReaction[]
  reports   CommunityReport[]
}

model CommunityPostImage {
  id         String        @id @default(uuid())
  postId     String
  imageUrl   String
  imageOrder Int           @default(0)
  createdAt  DateTime      @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model CommunityComment {
  id          String   @id @default(uuid())
  postId      String
  authorId    String
  commentText String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post   CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model CommunityReaction {
  id           String       @id @default(uuid())
  postId       String
  userId       String
  reactionType ReactionType
  createdAt    DateTime     @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model CommunityReport {
  id          String       @id @default(uuid())
  postId      String
  reportedBy  String
  reason      String?
  status      ReportStatus @default(OPEN)
  createdAt   DateTime     @default(now())
  reviewedBy  String?
  reviewedAt  DateTime?

  post     CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter User          @relation("CommunityReportReporter", fields: [reportedBy], references: [id], onDelete: Cascade)
  reviewer User?         @relation("CommunityReportReviewer", fields: [reviewedBy], references: [id], onDelete: Cascade)
}

model CommunityAlbum {
  id            String                  @id @default(uuid())
  title         String
  description   String?
  coverImageUrl String?
  createdBy     String
  isOfficial    Boolean                 @default(false)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  createdByUser User                    @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  images        CommunityAlbumImage[]
}

model CommunityAlbumImage {
  id         String          @id @default(uuid())
  albumId    String
  imageUrl   String
  caption    String?
  imageOrder Int             @default(0)
  uploadedBy String
  createdAt  DateTime        @default(now())

  album    CommunityAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  uploader User           @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(APPLICANT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile             ResidentProfile?
  applications        Application[]
  seasonMemberships   SeasonResident[]
  leases              Lease[]
  payments            Payment[]
  noticeReads         NoticeRead[]
  maintenanceRequests MaintenanceRequest[]
  checkIns            CheckIn[]
  checkOuts           CheckOut[]
  roomAssignments     RoomAssignment[]
  residentHouseAssignments ResidentHouseAssignment[]
  uploadedDocuments   Document[]
  supplyRequests      SupplyRequest[]
  residentReviews     ResidentReview[]
  sosAlerts           SosAlert[]
  communityPosts      CommunityPost[]
  communityComments   CommunityComment[]
  communityReactions  CommunityReaction[]
  communityReportsReported CommunityReport[] @relation("CommunityReportReporter")
  communityReportsReviewed CommunityReport[] @relation("CommunityReportReviewer")
  communityAlbumsCreated CommunityAlbum[]
  communityAlbumUploads CommunityAlbumImage[]
  adminDevices AdminDevice[]
  auditLogs AuditLog[]
}

model Season {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  year        Int
  term        String
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications  Application[]
  residents     SeasonResident[]
  notices       Notice[]
  galleryAlbums GalleryAlbum[]
  leases        Lease[]
  payments      Payment[]
  residentHouseAssignments ResidentHouseAssignment[]
}

model ResidentProfile {
  id                    String         @id @default(uuid())
  userId                String         @unique
  fullName              String
  phone                 String?
  country               String?
  passportNumber        String?
  sponsor               String?
  employer              String?
  emergencyContactName  String?
  emergencyContactPhone String?
  arrivalDate           DateTime?
  departureDate         DateTime?
  currentStatus         ResidentStatus @default(APPLICANT)
  avatarUrl             String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents Document[]
}

model Document {
  id        String       @id @default(uuid())
  profileId String
  userId    String
  type      DocumentType
  fileName  String
  filePath  String
  mimeType  String?
  fileSize  Int?
  createdAt DateTime     @default(now())

  profile ResidentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Application {
  id         String            @id @default(uuid())
  userId     String
  seasonId   String
  status     ApplicationStatus @default(PENDING)
  notes      String?
  appliedAt  DateTime          @default(now())
  reviewedAt DateTime?
  reviewedBy String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
}

model SeasonResident {
  id        String         @id @default(uuid())
  userId    String
  seasonId  String
  status    ResidentStatus @default(APPLICANT)
  joinedAt  DateTime       @default(now())
  leftAt    DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
}

model Property {
  id          String   @id @default(uuid())
  name        String
  address     String
  city        String   @default("Sevierville")
  state       String   @default("TN")
  zipCode     String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  buildings Building[]
}

model Building {
  id         String   @id @default(uuid())
  propertyId String
  name       String
  floors     Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  rooms    Room[]
}

model Room {
  id         String   @id @default(uuid())
  buildingId String
  roomNumber String
  capacity   Int      @default(2)
  floor      Int?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  building    Building         @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  beds        Bed[]
  assignments RoomAssignment[]

  @@unique([buildingId, roomNumber])
}

model Bed {
  id        String   @id @default(uuid())
  roomId    String
  bedLabel  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  room        Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  assignments RoomAssignment[]

  @@unique([roomId, bedLabel])
}

model RoomAssignment {
  id         String    @id @default(uuid())
  userId     String
  roomId     String
  bedId      String?
  seasonId   String?
  assignedAt DateTime  @default(now())
  vacatedAt  DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  bed  Bed? @relation(fields: [bedId], references: [id], onDelete: SetNull)
}

model HouseAssignment {
  id        String                @id @default(uuid())
  houseName String               @unique
  capacity  Int                  @default(0)
  occupancy Int                  @default(0)
  status    HouseAssignmentStatus @default(ACTIVE)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  residentAssignments ResidentHouseAssignment[]

  @@index([status, houseName])
  @@map("house_assignments")
}

model ResidentHouseAssignment {
  id                String    @id @default(uuid())
  userId            String
  houseAssignmentId String
  seasonId          String?
  assignedAt        DateTime  @default(now())
  vacatedAt         DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  houseAssignment HouseAssignment @relation(fields: [houseAssignmentId], references: [id], onDelete: Cascade)
  season          Season?         @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  @@index([userId, vacatedAt])
  @@index([houseAssignmentId, vacatedAt])
  @@map("resident_house_assignments")
}

model Lease {
  id             String    @id @default(uuid())
  userId         String?
  seasonId       String?
  title          String
  filePath       String?
  fileName       String?
  signedFilePath String?
  signedFileName String?
  status         LeaseWorkflowStatus @default(DRAFT)
  sentAt         DateTime?
  signedAt       DateTime?
  approvedAt     DateTime?
  approvedBy     String?
  completedAt    DateTime?
  archivedAt     DateTime?
  expiresAt      DateTime?
  acknowledged   Boolean   @default(false)
  acknowledgedAt DateTime?
  signatureData  String?
  signatureIp    String?
  signatureUserAgent String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  season Season? @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
}

model Payment {
  id              String        @id @default(uuid())
  userId          String
  seasonId        String
  type            PaymentType   @default(RENT)
  description     String?
  amountDue       Decimal       @db.Decimal(10, 2)
  amountPaid      Decimal       @default(0) @db.Decimal(10, 2)
  balance         Decimal       @db.Decimal(10, 2)
  dueDate         DateTime
  status          PaymentStatus @default(DUE)
  notes           String?
  receiptPath     String?
  receiptFileName String?
  receiptVerified Boolean       @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
}

model BusinessAccount {
  id               String   @id @default(uuid())
  slug             String   @unique @default("hideaway-holler")
  businessName     String   @default("Hideaway Holler")
  billingEmail     String?
  stripeCustomerId String?  @unique
  setupFeeAmount   Int      @default(0)
  setupFeeStatus   BusinessSetupFeeStatus @default(NOT_SENT)
  setupFeePaidAt   DateTime?
  isSuspended      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  subscriptions   BusinessSubscription[]
  invoices        BusinessInvoice[]
  payments        BusinessPayment[]
  billingSettings ClientBillingSettings?
  businessPlan    BusinessPlan?
  healthLogs      ClientAccountHealthLog[]
  serviceSubscription ClientServiceSubscription?
  serviceInvoices     ClientServiceInvoice[]
  clientPayments      ClientPayment[]

  @@map("business_accounts")
}

model ClientServiceSubscription {
  id                        String   @id @default(cuid())
  businessId                String   @unique
  serviceSubscriptionStatus String   @default("not_started")
  subscriptionStartDate     DateTime?
  firstPaymentDate          DateTime?
  billingDay                Int      @default(1)
  introMonthlyFee           Decimal  @default(149.00) @db.Decimal(10, 2)
  introDurationMonths       Int      @default(6)
  standardMonthlyFee        Decimal  @default(99.00) @db.Decimal(10, 2)
  taxRate                   Decimal  @default(0) @db.Decimal(5, 2)
  nextPaymentDate           DateTime?
  lastPaymentDate           DateTime?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  business BusinessAccount @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("client_service_subscriptions")
}

model ClientServiceInvoice {
  id                 String   @id @default(cuid())
  businessId         String
  invoiceNumber      String   @unique
  monthNumber        Int
  billingPeriodStart DateTime
  billingPeriodEnd   DateTime
  dueDate            DateTime
  subtotal           Decimal  @db.Decimal(10, 2)
  taxRate            Decimal  @db.Decimal(5, 2)
  taxAmount          Decimal  @db.Decimal(10, 2)
  totalDue           Decimal  @db.Decimal(10, 2)
  amountPaid         Decimal  @default(0) @db.Decimal(10, 2)
  balanceDue         Decimal  @db.Decimal(10, 2)
  status             String   @default("unpaid")
  paymentProvider    String?
  providerPaymentId  String?
  squareCheckoutUrl  String?
  squareOrderId      String?
  squarePaymentId    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  business BusinessAccount @relation(fields: [businessId], references: [id], onDelete: Cascade)
  payments ClientPayment[]

  @@index([businessId, status])
  @@index([businessId, monthNumber])
  @@map("client_service_invoices")
}

model ClientPayment {
  id                String   @id @default(cuid())
  businessId        String
  invoiceId         String?
  amount            Decimal  @db.Decimal(10, 2)
  paymentDate       DateTime @default(now())
  paymentMethod     String
  paymentProvider   String?
  providerPaymentId String?
  notes             String?
  createdAt         DateTime @default(now())

  business BusinessAccount        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice  ClientServiceInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([businessId, paymentDate])
  @@index([invoiceId])
  @@map("client_payments")
}

model ClientBillingSettings {
  id                        String                   @id @default(uuid())
  clientId                  String                   @unique
  setupFeeAmount            Int                      @default(0)
  setupFeeStatus            BusinessSetupFeeStatus   @default(NOT_SENT)
  monthlySubscriptionAmount Int                      @default(0)
  billingFrequency          BillingFrequency         @default(MONTHLY)
  billingStartDate          DateTime?
  nextBillingDate           DateTime?
  paymentDueDay             Int                      @default(1)
  gracePeriodDays           Int                      @default(7)
  subscriptionStatus        ClientSubscriptionStatus @default(INCOMPLETE)
  stripeCustomerId          String?
  stripeSubscriptionId      String?
  notes                     String?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt

  client BusinessAccount @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_billing_settings")
}

model BusinessPlan {
  id                        String           @id @default(uuid())
  clientId                  String           @unique
  planName                  String           @default("HollerHub Standard")
  monthlySubscriptionAmount Int              @default(0)
  setupFeeAmount            Int              @default(0)
  billingFrequency          BillingFrequency @default(MONTHLY)
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  client BusinessAccount @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("business_plans")
}

model ClientAccountHealthLog {
  id        String   @id @default(uuid())
  clientId  String
  status    String
  reasons   String[]
  createdAt DateTime @default(now())

  client BusinessAccount @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@map("client_account_health_logs")
}

model BusinessSubscription {
  id                   String                     @id @default(uuid())
  businessAccountId    String
  stripeSubscriptionId String?                    @unique
  stripeCustomerId     String?
  stripePriceId        String?
  planName             String?
  status               BusinessSubscriptionStatus @default(INCOMPLETE)
  cancelAtPeriodEnd    Boolean                    @default(false)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  trialEnd             DateTime?
  canceledAt           DateTime?
  latestInvoiceId      String?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  businessAccount BusinessAccount  @relation(fields: [businessAccountId], references: [id], onDelete: Cascade)
  invoices        BusinessInvoice[]
  payments        BusinessPayment[]

  @@index([businessAccountId, status])
  @@index([stripeCustomerId])
  @@map("business_subscriptions")
}

model BusinessInvoice {
  id                     String                @id @default(uuid())
  businessAccountId      String
  businessSubscriptionId String?
  stripeInvoiceId        String?               @unique
  invoiceNumber          String?
  invoiceType            BusinessInvoiceType   @default(CUSTOM_CHARGE)
  description            String?
  hostedInvoiceUrl       String?
  invoicePdf             String?
  stripeCheckoutUrl      String?
  amountDue              Int                   @default(0)
  amountPaid             Int                   @default(0)
  currency               String                @default("usd")
  status                 BusinessInvoiceStatus @default(PENDING)
  dueDate                DateTime?
  paidAt                 DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  businessAccount      BusinessAccount        @relation(fields: [businessAccountId], references: [id], onDelete: Cascade)
  businessSubscription BusinessSubscription?  @relation(fields: [businessSubscriptionId], references: [id], onDelete: SetNull)
  payments             BusinessPayment[]

  @@index([businessAccountId, status])
  @@index([businessSubscriptionId])
  @@map("business_invoices")
}

model BusinessPayment {
  id                     String                @id @default(uuid())
  businessAccountId      String
  businessSubscriptionId String?
  businessInvoiceId      String?
  stripePaymentIntentId  String?               @unique
  stripeChargeId         String?
  amount                 Int                   @default(0)
  currency               String                @default("usd")
  paymentMethod          BusinessPaymentMethod @default(STRIPE)
  status                 BusinessPaymentStatus @default(PENDING)
  receiptUrl             String?
  paidAt                 DateTime?
  failureMessage         String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  businessAccount      BusinessAccount        @relation(fields: [businessAccountId], references: [id], onDelete: Cascade)
  businessSubscription BusinessSubscription?  @relation(fields: [businessSubscriptionId], references: [id], onDelete: SetNull)
  businessInvoice      BusinessInvoice?       @relation(fields: [businessInvoiceId], references: [id], onDelete: SetNull)

  @@index([businessAccountId, status])
  @@index([businessSubscriptionId])
  @@index([businessInvoiceId])
  @@map("business_payments")
}

model Notice {
  id          String         @id @default(uuid())
  seasonId    String?
  title       String
  content     String
  category    NoticeCategory
  isPinned    Boolean        @default(false)
  isPublished Boolean        @default(true)
  publishedAt DateTime       @default(now())
  createdBy   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  season Season?      @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  reads  NoticeRead[]
}

model NoticeRead {
  id       String   @id @default(uuid())
  noticeId String
  userId   String
  readAt   DateTime @default(now())

  notice Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noticeId, userId])
}

model MaintenanceRequest {
  id          String              @id @default(uuid())
  userId      String
  category    MaintenanceCategory
  description String
  status      MaintenanceStatus   @default(OPEN)
  adminNotes  String?
  mediaPaths  String[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupplyRequest {
  id          String              @id @default(uuid())
  userId      String
  house       String
  supplyType  SupplyType
  quantity    Int                 @default(1)
  notes       String?
  status      SupplyRequestStatus @default(OPEN)
  fulfilledAt DateTime?
  fulfilledBy String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ResidentReview {
  id            String       @id @default(uuid())
  userId        String
  rating        Int
  title         String
  review        String
  photoPath     String?
  photoFileName String?
  status        ReviewStatus @default(PENDING)
  isFeatured    Boolean      @default(false)
  reviewedAt    DateTime?
  reviewedBy    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SosAlert {
  id                   String         @id @default(uuid())
  residentId           String
  residentName         String
  assignment           String?
  phone                String?
  status               SosAlertStatus @default(ACTIVE)
  initialLatitude      Float
  initialLongitude     Float
  currentLatitude      Float?
  currentLongitude     Float?
  accuracy             Float?
  streetAddress        String?
  landmark             String?
  adminAcknowledged    Boolean        @default(false)
  adminAcknowledgedAt  DateTime?
  adminAcknowledgedBy  String?
  trackingActive       Boolean        @default(false)
  trackingStartedAt    DateTime?
  residentLastResponse String?
  residentRespondedAt  DateTime?
  resolvedAt           DateTime?
  resolvedBy           String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  resident        User                 @relation(fields: [residentId], references: [id], onDelete: Cascade)
  locationHistory SosLocationHistory[]
  eventLogs       SosEventLog[]
  emergencyAlert  EmergencyAlert?
  notificationLogs EmergencyNotificationLog[]

  @@index([residentId, status])
  @@index([status, createdAt])
  @@map("sos_alerts")
}

model SosEventLog {
  id           String       @id @default(uuid())
  sosAlertId   String
  residentId   String?
  adminId      String?
  eventType    SosEventType
  eventMessage String
  latitude     Float?
  longitude    Float?
  createdAt    DateTime     @default(now())

  alert SosAlert @relation(fields: [sosAlertId], references: [id], onDelete: Cascade)

  @@index([sosAlertId, createdAt])
  @@index([eventType, createdAt])
  @@map("sos_event_logs")
}

model SosLocationHistory {
  id            String   @id @default(uuid())
  sosAlertId    String
  residentId    String?
  latitude      Float
  longitude     Float
  accuracy      Float?
  speed         Float?
  heading       Float?
  streetAddress String?
  landmark      String?
  recordedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  alert SosAlert @relation(fields: [sosAlertId], references: [id], onDelete: Cascade)

  @@index([sosAlertId, createdAt])
  @@map("sos_location_history")
}

model AdminDevice {
  id          String   @id @default(uuid())
  adminId     String
  endpoint    String   @unique
  p256dh      String
  auth        String
  userAgent   String?
  deviceLabel String?
  enabled     Boolean  @default(true)
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admin            User                       @relation(fields: [adminId], references: [id], onDelete: Cascade)
  notificationLogs EmergencyNotificationLog[]

  @@index([adminId, enabled])
  @@map("admin_devices")
}

model EmergencyAlert {
  id             String    @id @default(uuid())
  sosAlertId     String    @unique
  status         String    @default("ACTIVE")
  acknowledgedAt DateTime?
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sosAlert         SosAlert                   @relation(fields: [sosAlertId], references: [id], onDelete: Cascade)
  notificationLogs EmergencyNotificationLog[]

  @@index([status, createdAt])
  @@map("emergency_alerts")
}

model EmergencyNotificationLog {
  id               String   @id @default(uuid())
  emergencyAlertId String?
  sosAlertId       String?
  adminDeviceId    String?
  channel          String
  status           String
  message          String?
  createdAt        DateTime @default(now())

  emergencyAlert EmergencyAlert? @relation(fields: [emergencyAlertId], references: [id], onDelete: Cascade)
  sosAlert       SosAlert?       @relation(fields: [sosAlertId], references: [id], onDelete: Cascade)
  adminDevice    AdminDevice?    @relation(fields: [adminDeviceId], references: [id], onDelete: SetNull)

  @@index([sosAlertId, createdAt])
  @@index([emergencyAlertId, createdAt])
  @@index([channel, status, createdAt])
  @@map("emergency_notification_logs")
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actorRole  UserRole?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

model GalleryAlbum {
  id          String   @id @default(uuid())
  seasonId    String?
  title       String
  description String?
  coverPath   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  season Season?        @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  images GalleryImage[]
}

model GalleryImage {
  id        String   @id @default(uuid())
  albumId   String
  filePath  String
  fileName  String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  album GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
}

model LocalGuide {
  id          String             @id @default(uuid())
  name        String
  category    LocalGuideCategory
  description String?
  address     String?
  phone       String?
  website     String?
  mapLink     String?
  isFeatured  Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model CheckIn {
  id               String    @id @default(uuid())
  userId           String
  seasonId         String?
  arrivalConfirmed Boolean   @default(false)
  rulesAccepted    Boolean   @default(false)
  roomCondition    String?
  roomPhotoPaths   String[]
  adminApproved    Boolean   @default(false)
  adminApprovedAt  DateTime?
  adminNotes       String?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CheckOut {
  id              String    @id @default(uuid())
  userId          String
  seasonId        String?
  moveOutNotes    String?
  damageReport    String?
  roomPhotoPaths  String[]
  inspectionNotes String?
  depositReview   String?
  adminApproved   Boolean   @default(false)
  adminApprovedAt DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmergencyContact {
  id          String  @id @default(uuid())
  label       String
  phone       String
  description String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)
}

model SiteSettings {
  id    String @id @default("default")
  key   String @unique
  value String
}
