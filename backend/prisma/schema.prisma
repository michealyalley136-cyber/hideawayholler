generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  APPLICANT
  RESIDENT
  ALUMNI
  ADMIN
}

enum ResidentStatus {
  APPLICANT
  APPROVED
  LEASE_SENT
  LEASE_SIGNED
  DEPOSIT_RECEIVED
  ROOM_ASSIGNED
  CHECKED_IN
  ACTIVE_RESIDENT
  CHECKED_OUT
  ALUMNI
}

enum DocumentType {
  PASSPORT
  VISA
  JOB_OFFER
  OTHER
}

enum PaymentStatus {
  PAID
  PARTIAL
  DUE
  OVERDUE
}

enum PaymentType {
  RENT
  DEPOSIT
  OTHER
}

enum NoticeCategory {
  RULES
  COMMUNITY
  RENT_REMINDER
  WEATHER
  EMERGENCY
  EVENT
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  APPLIANCE
  CLEANING
  OTHER
}

enum MaintenanceStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
}

enum LocalGuideCategory {
  FOOD
  SHOPPING
  TRANSPORTATION
  HEALTHCARE
  BANKS
  ATTRACTIONS
  EMERGENCY
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
}

enum SupplyType {
  TOILET_PAPER
  PAPER_TOWELS
  TRASH_BAGS
  CLEANING_SUPPLIES
  DISH_SOAP
  LAUNDRY_SUPPLIES
  OTHER
}

enum SupplyRequestStatus {
  OPEN
  FULFILLED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SosAlertStatus {
  ACTIVE
  ACKNOWLEDGED
  SAFE
  NEEDS_HELP
  RESOLVED
}

enum SosEventType {
  SOS_TRIGGERED
  ADMIN_NOTIFIED
  ADMIN_ACKNOWLEDGED
  RESIDENT_CONFIRMED_SAFE
  TRACKING_STARTED
  LOCATION_UPDATED
  ADMIN_MARKED_RESOLVED
  SOS_RESOLVED
  SOS_MUTED
}

enum CommunityPostType {
  RESIDENT_MEMORY
  ADMIN_EVENT
  ANNOUNCEMENT_PHOTO
  ANIMAL_MOMENT
  COMMUNITY_ACTIVITY
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReactionType {
  LIKE
  LOVE
  SMILE
}

enum ReportStatus {
  OPEN
  REVIEWED
  RESOLVED
}

model CommunityPost {
  id              String              @id @default(uuid())
  authorId        String
  authorRole      UserRole
  caption         String?
  postType        CommunityPostType  @default(RESIDENT_MEMORY)
  approvalStatus  ApprovalStatus      @default(PENDING)
  isPinned        Boolean             @default(false)
  commentsEnabled Boolean             @default(true)
  isOfficial      Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  author    User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  images    CommunityPostImage[]
  comments  CommunityComment[]
  reactions CommunityReaction[]
  reports   CommunityReport[]
}

model CommunityPostImage {
  id         String        @id @default(uuid())
  postId     String
  imageUrl   String
  imageOrder Int           @default(0)
  createdAt  DateTime      @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model CommunityComment {
  id          String   @id @default(uuid())
  postId      String
  authorId    String
  commentText String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post   CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model CommunityReaction {
  id           String       @id @default(uuid())
  postId       String
  userId       String
  reactionType ReactionType
  createdAt    DateTime     @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model CommunityReport {
  id          String       @id @default(uuid())
  postId      String
  reportedBy  String
  reason      String?
  status      ReportStatus @default(OPEN)
  createdAt   DateTime     @default(now())
  reviewedBy  String?
  reviewedAt  DateTime?

  post     CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter User          @relation("CommunityReportReporter", fields: [reportedBy], references: [id], onDelete: Cascade)
  reviewer User?         @relation("CommunityReportReviewer", fields: [reviewedBy], references: [id], onDelete: Cascade)
}

model CommunityAlbum {
  id            String                  @id @default(uuid())
  title         String
  description   String?
  coverImageUrl String?
  createdBy     String
  isOfficial    Boolean                 @default(false)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  createdByUser User                    @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  images        CommunityAlbumImage[]
}

model CommunityAlbumImage {
  id         String          @id @default(uuid())
  albumId    String
  imageUrl   String
  caption    String?
  imageOrder Int             @default(0)
  uploadedBy String
  createdAt  DateTime        @default(now())

  album    CommunityAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  uploader User           @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(APPLICANT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile             ResidentProfile?
  applications        Application[]
  seasonMemberships   SeasonResident[]
  leases              Lease[]
  payments            Payment[]
  noticeReads         NoticeRead[]
  maintenanceRequests MaintenanceRequest[]
  checkIns            CheckIn[]
  checkOuts           CheckOut[]
  roomAssignments     RoomAssignment[]
  uploadedDocuments   Document[]
  supplyRequests      SupplyRequest[]
  residentReviews     ResidentReview[]
  sosAlerts           SosAlert[]
  communityPosts      CommunityPost[]
  communityComments   CommunityComment[]
  communityReactions  CommunityReaction[]
  communityReportsReported CommunityReport[] @relation("CommunityReportReporter")
  communityReportsReviewed CommunityReport[] @relation("CommunityReportReviewer")
  communityAlbumsCreated CommunityAlbum[]
  communityAlbumUploads CommunityAlbumImage[]
}

model Season {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  year        Int
  term        String
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications  Application[]
  residents     SeasonResident[]
  notices       Notice[]
  galleryAlbums GalleryAlbum[]
  leases        Lease[]
  payments      Payment[]
}

model ResidentProfile {
  id                    String         @id @default(uuid())
  userId                String         @unique
  fullName              String
  phone                 String?
  country               String?
  passportNumber        String?
  sponsor               String?
  employer              String?
  emergencyContactName  String?
  emergencyContactPhone String?
  arrivalDate           DateTime?
  departureDate         DateTime?
  currentStatus         ResidentStatus @default(APPLICANT)
  avatarUrl             String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents Document[]
}

model Document {
  id        String       @id @default(uuid())
  profileId String
  userId    String
  type      DocumentType
  fileName  String
  filePath  String
  mimeType  String?
  fileSize  Int?
  createdAt DateTime     @default(now())

  profile ResidentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Application {
  id         String            @id @default(uuid())
  userId     String
  seasonId   String
  status     ApplicationStatus @default(PENDING)
  notes      String?
  appliedAt  DateTime          @default(now())
  reviewedAt DateTime?
  reviewedBy String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
}

model SeasonResident {
  id        String         @id @default(uuid())
  userId    String
  seasonId  String
  status    ResidentStatus @default(APPLICANT)
  joinedAt  DateTime       @default(now())
  leftAt    DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
}

model Property {
  id          String   @id @default(uuid())
  name        String
  address     String
  city        String   @default("Sevierville")
  state       String   @default("TN")
  zipCode     String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  buildings Building[]
}

model Building {
  id         String   @id @default(uuid())
  propertyId String
  name       String
  floors     Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  rooms    Room[]
}

model Room {
  id         String   @id @default(uuid())
  buildingId String
  roomNumber String
  capacity   Int      @default(2)
  floor      Int?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  building    Building         @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  beds        Bed[]
  assignments RoomAssignment[]

  @@unique([buildingId, roomNumber])
}

model Bed {
  id        String   @id @default(uuid())
  roomId    String
  bedLabel  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  room        Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  assignments RoomAssignment[]

  @@unique([roomId, bedLabel])
}

model RoomAssignment {
  id         String    @id @default(uuid())
  userId     String
  roomId     String
  bedId      String?
  seasonId   String?
  assignedAt DateTime  @default(now())
  vacatedAt  DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  bed  Bed? @relation(fields: [bedId], references: [id], onDelete: SetNull)
}

model Lease {
  id             String    @id @default(uuid())
  userId         String
  seasonId       String
  title          String
  filePath       String?
  fileName       String?
  sentAt         DateTime?
  signedAt       DateTime?
  expiresAt      DateTime?
  acknowledged   Boolean   @default(false)
  acknowledgedAt DateTime?
  signatureData  String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String        @id @default(uuid())
  userId          String
  seasonId        String
  type            PaymentType   @default(RENT)
  description     String?
  amountDue       Decimal       @db.Decimal(10, 2)
  amountPaid      Decimal       @default(0) @db.Decimal(10, 2)
  balance         Decimal       @db.Decimal(10, 2)
  dueDate         DateTime
  status          PaymentStatus @default(DUE)
  notes           String?
  receiptPath     String?
  receiptFileName String?
  receiptVerified Boolean       @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
}

model Notice {
  id          String         @id @default(uuid())
  seasonId    String?
  title       String
  content     String
  category    NoticeCategory
  isPinned    Boolean        @default(false)
  isPublished Boolean        @default(true)
  publishedAt DateTime       @default(now())
  createdBy   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  season Season?      @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  reads  NoticeRead[]
}

model NoticeRead {
  id       String   @id @default(uuid())
  noticeId String
  userId   String
  readAt   DateTime @default(now())

  notice Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noticeId, userId])
}

model MaintenanceRequest {
  id          String              @id @default(uuid())
  userId      String
  category    MaintenanceCategory
  description String
  status      MaintenanceStatus   @default(OPEN)
  adminNotes  String?
  mediaPaths  String[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupplyRequest {
  id          String              @id @default(uuid())
  userId      String
  house       String
  supplyType  SupplyType
  quantity    Int                 @default(1)
  notes       String?
  status      SupplyRequestStatus @default(OPEN)
  fulfilledAt DateTime?
  fulfilledBy String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ResidentReview {
  id            String       @id @default(uuid())
  userId        String
  rating        Int
  title         String
  review        String
  photoPath     String?
  photoFileName String?
  status        ReviewStatus @default(PENDING)
  isFeatured    Boolean      @default(false)
  reviewedAt    DateTime?
  reviewedBy    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SosAlert {
  id                   String         @id @default(uuid())
  residentId           String
  residentName         String
  assignment           String?
  phone                String?
  status               SosAlertStatus @default(ACTIVE)
  initialLatitude      Float
  initialLongitude     Float
  currentLatitude      Float?
  currentLongitude     Float?
  accuracy             Float?
  streetAddress        String?
  landmark             String?
  adminAcknowledged    Boolean        @default(false)
  adminAcknowledgedAt  DateTime?
  adminAcknowledgedBy  String?
  trackingActive       Boolean        @default(false)
  trackingStartedAt    DateTime?
  residentLastResponse String?
  residentRespondedAt  DateTime?
  resolvedAt           DateTime?
  resolvedBy           String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  resident        User                 @relation(fields: [residentId], references: [id], onDelete: Cascade)
  locationHistory SosLocationHistory[]
  eventLogs       SosEventLog[]

  @@index([residentId, status])
  @@index([status, createdAt])
  @@map("sos_alerts")
}

model SosEventLog {
  id           String       @id @default(uuid())
  sosAlertId   String
  residentId   String?
  adminId      String?
  eventType    SosEventType
  eventMessage String
  latitude     Float?
  longitude    Float?
  createdAt    DateTime     @default(now())

  alert SosAlert @relation(fields: [sosAlertId], references: [id], onDelete: Cascade)

  @@index([sosAlertId, createdAt])
  @@index([eventType, createdAt])
  @@map("sos_event_logs")
}

model SosLocationHistory {
  id            String   @id @default(uuid())
  sosAlertId    String
  residentId    String?
  latitude      Float
  longitude     Float
  accuracy      Float?
  speed         Float?
  heading       Float?
  streetAddress String?
  landmark      String?
  recordedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  alert SosAlert @relation(fields: [sosAlertId], references: [id], onDelete: Cascade)

  @@index([sosAlertId, createdAt])
  @@map("sos_location_history")
}

model GalleryAlbum {
  id          String   @id @default(uuid())
  seasonId    String?
  title       String
  description String?
  coverPath   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  season Season?        @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  images GalleryImage[]
}

model GalleryImage {
  id        String   @id @default(uuid())
  albumId   String
  filePath  String
  fileName  String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  album GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
}

model LocalGuide {
  id          String             @id @default(uuid())
  name        String
  category    LocalGuideCategory
  description String?
  address     String?
  phone       String?
  website     String?
  mapLink     String?
  isFeatured  Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model CheckIn {
  id               String    @id @default(uuid())
  userId           String
  seasonId         String?
  arrivalConfirmed Boolean   @default(false)
  rulesAccepted    Boolean   @default(false)
  roomCondition    String?
  roomPhotoPaths   String[]
  adminApproved    Boolean   @default(false)
  adminApprovedAt  DateTime?
  adminNotes       String?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CheckOut {
  id              String    @id @default(uuid())
  userId          String
  seasonId        String?
  moveOutNotes    String?
  damageReport    String?
  roomPhotoPaths  String[]
  inspectionNotes String?
  depositReview   String?
  adminApproved   Boolean   @default(false)
  adminApprovedAt DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmergencyContact {
  id          String  @id @default(uuid())
  label       String
  phone       String
  description String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)
}

model SiteSettings {
  id    String @id @default("default")
  key   String @unique
  value String
}
